*.tsbuildinfo
next-env.d.ts

# clerk configuration (can include secrets)
/.clerk/

/src/generated/prisma

__pycache__

# Sentry Config File
.env.sentry-build-plugin

# scripts tooling
scripts/node_modules/
scripts/package-lock.json
scripts/system-voices/
scripts/system-voices-cmu/
scripts/system-voices-librivox/
scripts/system-voices-vctk/
scripts/system-voices-libritts/

